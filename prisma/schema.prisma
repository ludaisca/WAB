generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  name     String?
  email    String   @unique
  password String?
  role     String   @default("user")
  maxOpenChats Int?

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  waAccounts     WAAccount[]
  waCampaigns    WACampaign[]
  waBots         WABot[]
  leadScorerBots WALeadScorerBot[]
  appSettings    AppSettings?
  googleAccount  GoogleAccount?
  sharedAccounts WAAccountShare[]
  notes          WANote[]
  assignedChats  WAChat[]         @relation("ChatAssignments")
  notifications  Notification[]
  sentMessages   WAMessage[]
  leadSheetSources LeadSheetSource[]
  sheetExports     SheetExport[]

  @@map("users")
}

model SystemConfig {
  id                 String   @id @default("default")
  allowRegistration  Boolean  @default(true)
  businessName       String?
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model AppSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  openrouterApiKey String?
  googleApiKey     String?
  defaultProvider  String   @default("openrouter")
  defaultModel     String   @default("google/gemini-2.5-flash")
  monthlyBudgetUsd Float?
  budgetAlertMonth String?

  // Recuperación de leads: config global por usuario, aplica a todas sus
  // cuentas de WhatsApp. secondMessageHours null = solo se manda 1 mensaje.
  leadRecoveryEnabled            Boolean  @default(false)
  leadRecoveryFirstMessageHours  Int      @default(2)
  leadRecoverySecondMessageHours Int?     @default(12)
  leadRecoveryBusinessHourStart  Int      @default(8)
  leadRecoveryBusinessHourEnd    Int      @default(20)
  leadRecoveryTimezone           String   @default("America/Mexico_City")

  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// Conexión OAuth por usuario a Google (Sheets). A diferencia de WAAccount/AppSettings
// (secretos estáticos que no expiran), accessToken/refreshToken son un par OAuth que
// se refresca en runtime — ver lib/google/sheets-client.ts. Ambos se guardan cifrados
// con lib/crypto.ts, igual que los demás secretos del proyecto.
model GoogleAccount {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleEmail          String
  accessToken          String
  refreshToken         String
  accessTokenExpiresAt DateTime
  scope                String
  spreadsheetId        String?
  enabled              Boolean   @default(true)
  lastSyncedAt         DateTime?
  lastSyncError        String?
  // Compare-and-swap para el backfill único de las 2 exportaciones legado
  // (Leads calificados/Resultados de campaña) hacia SheetExport — null hasta
  // que un runner lo reclama vía updateMany(where:{legacyExportsMigratedAt:null}).
  // Sync-now corre fuera de la cola BullMQ y el tick de 15 min corre dentro,
  // así que pueden solaparse: un simple count()===0 tendría ventana de carrera.
  legacyExportsMigratedAt DateTime?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("google_accounts")
}

// Exportación configurable a una hoja de Google Sheets — reemplaza la
// sincronización hardcodeada de 2 datasets fijos que existía antes (ver
// GoogleAccount.legacyExportsMigratedAt para la migración). Cada usuario puede
// crear varias, cada una eligiendo dataset, columnas, filtros y hoja/pestaña
// destino de forma independiente. Ownership directo por userId (no vía
// WAAccount/getUserAccountIds) — GoogleAccount ya es 1:1 por usuario.
model SheetExport {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  dataset       SheetExportDataset
  spreadsheetId String
  sheetName     String
  // Subconjunto de las keys de EXPORT_COLUMNS_BY_DATASET[dataset] — el orden
  // real de escritura lo decide el orden canónico de esa definición, no el
  // orden guardado aquí (ver lib/google/sheet-export-runner.ts).
  columns       String[]            @default([])
  // Forma depende de `dataset` — ver los 4 schemas de lib/validations.ts y
  // lib/google/dataset-queries.ts. Un id referenciado (tag/campaña/calificador)
  // que luego se borra no rompe nada: simplemente deja de matchear en la query.
  filters       Json                @default("{}")
  enabled       Boolean             @default(true)
  lastSyncedAt  DateTime?
  lastSyncError String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  // Sin esto, dos exportaciones apuntando a la misma pestaña se pisarían en
  // cada ciclo de sync (writeSheetTab hace clear+update del rango completo)
  // sin ningún error visible — el POST captura P2002 y devuelve 409. Global
  // (no incluye userId a propósito): dos USUARIOS distintos con acceso Editor
  // a la misma hoja externa también se pisarían entre sí si cada uno pudiera
  // crear su propio export sobre la misma (spreadsheetId, sheetName) — no hay
  // caso legítimo para dos exports escribiendo la misma pestaña a la vez.
  @@unique([spreadsheetId, sheetName])
  @@index([userId])
  @@map("sheet_exports")
}

enum SheetExportDataset {
  LEAD_SCORES
  CAMPAIGN_RESULTS
  CHATS
  CONTACTS
}

model WAAccount {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  channel         WAChannel        @default(META_CLOUD)
  phoneNumber     String?
  phoneNumberId   String?
  wabaId          String?
  // Meta App ID that owns accessToken — required only for the Resumable Upload
  // API used when creating a template with a media header (distinct from wabaId,
  // which scopes template/message sends). Different WABA accounts can belong to
  // different Meta Apps, so this is per-account rather than a global env var.
  appId           String?
  accessToken     String?
  verifyTokenHash String?
  appSecret       String?
  status            WaAccountStatus  @default(PENDING)
  errorMessage      String?
  lastActivity      DateTime?
  autoAssignEnabled Boolean          @default(false)
  // Cuando está activo, los roles `user` y `ejecutivo` solo ven los chats de
  // esta cuenta que tengan atribución (campaña masiva o automatización de
  // Sheets). El admin siempre ve todo. Ver lib/whatsapp/chat-visibility.ts.
  hideUnattributedChats Boolean      @default(false)
  // Reportados por el webhook `phone_number_quality_update` de Meta — no se
  // consultan por API, solo llegan de forma reactiva (push). qualityRating es
  // el valor crudo que manda Meta (p. ej. "GREEN"/"YELLOW"/"RED" o el nombre
  // del evento "FLAGGED"/"UNFLAGGED"); messagingTier es el límite de envío por
  // 24h vigente (p. ej. "TIER_1K"). Ambos null hasta el primer evento recibido.
  qualityRating     String?
  messagingTier     String?
  qualityUpdatedAt  DateTime?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  chats           WAChat[]
  templates       WATemplate[]
  campaigns       WACampaign[]
  bots            WABot[]
  sharedWith      WAAccountShare[]
  contacts        Contact[]

  cannedResponses CannedResponse[]
  leadSheetSources LeadSheetSource[]

  @@index([phoneNumberId])
  @@unique([phoneNumberId])
  @@unique([userId, name])
  @@map("wa_accounts")
}

model CannedResponse {
  id          String    @id @default(cuid())
  waAccountId String
  waAccount   WAAccount @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  shortcut    String
  content     String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([waAccountId, shortcut])
  @@map("canned_responses")
}

enum WAChannel {
  META_CLOUD
}

model WAAccountShare {
  id          String    @id @default(cuid())
  waAccountId String
  waAccount   WAAccount @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([waAccountId, userId])
  @@map("wa_account_shares")
}

enum WaAccountStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum ChatStatus {
  OPEN
  PENDING
  RESOLVED
}

model WAChat {
  id            String     @id @default(cuid())
  accountId     String
  account       WAAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  remoteJid     String
  name          String?
  isGroup       Boolean    @default(false)
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int        @default(0)
  contactId     String?    @unique
  contact       Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedToId  String?
  assignedTo    User?      @relation("ChatAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)
  status          ChatStatus @default(OPEN)
  resolvedAt      DateTime?
  firstResponseAt DateTime?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  messages         WAMessage[]
  botConversations WABotConversation[]
  chatTags         ChatTag[]
  leadScores       WALeadScore[]
  recoveryAttempts WALeadRecoveryAttempt[]

  @@unique([accountId, remoteJid])
  @@index([assignedToId])
  @@index([accountId, lastMessageAt])
  @@index([accountId, status])
  @@map("wa_chats")
}

model WALeadScorerBot {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                    String
  provider                String
  model                   String
  systemPrompt            String    @db.Text
  isActive                Boolean   @default(true)
  scheduleEnabled         Boolean   @default(false)
  scheduleIntervalMinutes Int?
  scheduleAccountIds      String[]  @default([])
  lastRunAt               DateTime?
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  scores WALeadScore[]
  usage  WALeadScorerUsage[]

  @@unique([userId, name])
  @@map("wa_lead_scorer_bots")
}

model WALeadScorerUsage {
  id               String          @id @default(cuid())
  scorerId         String
  scorer           WALeadScorerBot @relation(fields: [scorerId], references: [id], onDelete: Cascade)
  waChatId         String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([scorerId, createdAt])
  @@map("wa_lead_scorer_usage")
}

model WALeadScore {
  id        String          @id @default(cuid())
  chatId    String
  chat      WAChat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  scorerId  String
  scorer    WALeadScorerBot @relation(fields: [scorerId], references: [id], onDelete: Cascade)
  score     Int
  label     String
  summary   String
  reasons   String
  // Structured extraction beyond score/label (señales de compra, objeciones,
  // próximos pasos, producto de interés, etc.) — kept as a single flexible
  // JSON blob instead of a dozen typed columns since its shape is dictated by
  // the prompt contract in lib/whatsapp/lead-scoring.ts, not by relational
  // needs elsewhere in the schema. Null for scores generated before this field.
  details   Json?
  model     String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([chatId, scorerId])
  @@map("wa_lead_scores")
}

model WAMessage {
  id          String           @id @default(cuid())
  wamid       String?
  chatId      String
  chat        WAChat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  direction   MessageDirection
  messageType String
  body        String?
  caption     String?
  mediaId     String?
  mediaUrl    String?
  mimeType    String?
  filename    String?
  bytesSize   Int?
  status      String?
  senderId    String?
  sender      User?            @relation(fields: [senderId], references: [id], onDelete: SetNull)
  campaignId  String?
  campaign    WACampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  // Igual que campaignId pero para envíos disparados por una fuente de leads
  // externa (LeadSheetSource) — nunca ambos a la vez, cada WAMessage viene de
  // como mucho un origen. Ver lib/whatsapp/chat-attribution.ts para cómo se
  // unifican ambos campos en una sola "atribución" del chat.
  leadSheetSourceId String?
  leadSheetSource   LeadSheetSource? @relation(fields: [leadSheetSourceId], references: [id], onDelete: SetNull)
  timestamp   DateTime
  createdAt   DateTime         @default(now()) @map("created_at")

  recoveryAttempt WALeadRecoveryAttempt?

  @@unique([chatId, wamid])
  @@index([wamid])
  @@index([chatId, timestamp])
  @@index([chatId, direction])
  @@index([campaignId])
  @@index([leadSheetSourceId])
  @@map("wa_messages")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// Registra cada mensaje de reactivación enviado a un chat que se quedó
// callado — attemptNumber (1 o 2) + createdAt permiten calcular en qué etapa
// va un chat sin tener que resetear nada manualmente cuando el lead responde:
// solo se cuentan los intentos con createdAt posterior al último INBOUND.
model WALeadRecoveryAttempt {
  id               String    @id @default(cuid())
  chatId           String
  chat             WAChat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  attemptNumber    Int
  messageId        String    @unique
  message          WAMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([chatId, createdAt])
  @@map("wa_lead_recovery_attempts")
}

model WATemplate {
  id          String   @id @default(cuid())
  waAccountId String
  waAccount   WAAccount @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  templateId  String
  name        String
  language    String
  category    String
  status      String
  components  Json
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  campaigns WACampaign[]
  leadSheetSources LeadSheetSource[]

  @@unique([waAccountId, templateId])
  @@map("wa_templates")
}

// Fuente de leads externa (hoja de Google Sheets, típicamente alimentada por la
// sincronización nativa de Facebook Lead Ads → Sheets). A diferencia de GoogleAccount
// (una hoja por usuario, la que WAB crea para exportar), spreadsheetId aquí es una hoja
// arbitraria del usuario — la misma conexión OAuth (lib/google/sheets-client.ts) sirve
// para leerla porque el scope otorgado no está restringido a los archivos creados por WAB.
model LeadSheetSource {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  waAccountId   String
  waAccount     WAAccount  @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  waTemplateId  String
  waTemplate    WATemplate @relation(fields: [waTemplateId], references: [id], onDelete: Cascade)
  name          String
  spreadsheetId String
  sheetName     String
  phoneColumn   String
  nameColumn    String?
  // Columna con la fecha en que el lead dejó sus datos en el formulario. La
  // elige el usuario al conectar la fuente en vez de inferirse del encabezado:
  // los exports de Meta Lead Ads no traen un nombre de columna consistente.
  dateColumn    String?
  // Nombres de columna de la hoja, en el orden {{1}},{{2}},... del body de la plantilla.
  bodyColumns   Json
  // Igual que WACampaign.headerParam/buttonParam: valores estáticos (no por fila) —
  // texto o Meta media id para el header, sufijo de URL para el botón dinámico.
  headerParam   String?
  buttonParam   String?
  // Rotación round-robin de UNA variable del body, para repartir los leads de
  // forma equitativa entre ejecutivos (el lead 1 recibe el nombre del ejecutivo A,
  // el 2 el del B, el 3 vuelve al A...). rotatingParamIndex es 0-based sobre las
  // variables del body; cuando está puesto, esa posición ignora bodyColumns y
  // toma su valor de rotatingValues. El cursor persiste entre corridas para que
  // la rotación no se reinicie en cada tick, y solo avanza con envíos exitosos.
  rotatingParamIndex Int?
  rotatingValues     Json?
  rotationCursor     Int     @default(0)
  enabled       Boolean    @default(true)
  lastRunAt     DateTime?
  lastImportedCount Int    @default(0)
  lastError     String?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  importedRows LeadSheetImportedRow[]
  messages     WAMessage[]

  @@index([userId])
  @@index([waAccountId])
  @@map("lead_sheet_sources")
}

// Log de deduplicación: una fila por (fuente, teléfono) ya vista, para no volver
// a disparar la plantilla al mismo lead en ticks futuros. "seeded" = fila que ya
// existía en la hoja al conectar la fuente (se ignora salvo import manual explícito).
model LeadSheetImportedRow {
  id           String          @id @default(cuid())
  sourceId     String
  source       LeadSheetSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  phoneNumber  String
  contactName  String?
  // status: "sent" | "delivered" | "read" | "failed" | "skipped" | "seeded" —
  // delivered/read los pone el webhook de Meta (ver applyStatusUpdate), igual
  // que en WACampaignRecipient.
  status       String
  wamid        String?
  deliveredAt  DateTime?
  readAt       DateTime?
  errorMessage String?
  // Valor que tocó en la rotación round-robin (p. ej. el ejecutivo asignado),
  // para poder auditar a quién se le atribuyó cada lead.
  rotatedValue String?
  // Fecha de registro del lead tomada de dateColumn. Se guarda el texto tal cual
  // viene de la hoja (leadDateRaw) además de la versión parseada, para no perder
  // el dato cuando el formato no se puede interpretar.
  leadDateRaw  String?
  leadDate     DateTime?
  importedAt   DateTime        @default(now())

  @@unique([sourceId, phoneNumber])
  @@index([wamid])
  @@map("lead_sheet_imported_rows")
}

model WACampaign {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  waAccountId     String
  waAccount       WAAccount            @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  waTemplateId    String
  waTemplate      WATemplate           @relation(fields: [waTemplateId], references: [id], onDelete: Cascade)
  name            String
  status          CampaignStatus       @default(DRAFT)
  // Global values applied to every recipient — unlike body parameters (per-recipient,
  // see WACampaignRecipient.parameters), header text/media and button URL suffixes are
  // the same for the whole campaign in WhatsApp's template model.
  headerParam     String?
  buttonParam     String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  recipientCount  Int                  @default(0)
  sentCount       Int                  @default(0)
  deliveredCount  Int                  @default(0)
  readCount       Int                  @default(0)
  failedCount     Int                  @default(0)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  recipients WACampaignRecipient[]
  messages   WAMessage[]

  @@index([userId])
  @@index([waAccountId])
  @@map("wa_campaigns")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

model WACampaignRecipient {
  id           String          @id @default(cuid())
  campaignId   String
  campaign     WACampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  phoneNumber  String
  contactName  String?
  wamid        String?
  parameters   Json?
  status       RecipientStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?

  @@index([wamid])
  @@index([campaignId, status])
  @@map("wa_campaign_recipients")
}

enum RecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model WABot {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  waAccountId  String?
  waAccount    WAAccount?    @relation(fields: [waAccountId], references: [id], onDelete: SetNull)
  name         String
  provider     String
  model        String
  systemPrompt String        @db.Text
  temperature  Float         @default(0.7)
  maxTokens    Int           @default(1024)
  memoryType   BotMemoryType @default(RECENT)
  memoryLimit  Int           @default(20)
  ragEnabled   Boolean       @default(false)
  humanizeEnabled Boolean    @default(false)
  isActive     Boolean       @default(false)
  status       BotStatus     @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  conversations WABotConversation[]
  knowledgeBots WABotKnowledgeBot[]
  usage         WABotUsage[]

  @@unique([userId, name])
  @@map("wa_bots")
}

enum BotMemoryType {
  NONE
  RECENT
  SUMMARY
}

enum BotStatus {
  ACTIVE
  ERROR
}

model WABotConversation {
  id              String   @id @default(cuid())
  botId           String
  bot             WABot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  waChatId        String
  waChat          WAChat   @relation(fields: [waChatId], references: [id], onDelete: Cascade)
  summary         String?  @db.Text

  @@unique([botId, waChatId])
  @@map("wa_bot_conversations")
}

model WABotKnowledge {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  embedding  Unsupported("vector(768)")
  chunkIndex Int
  sourceName String?
  createdAt  DateTime @default(now()) @map("created_at")

  bots WABotKnowledgeBot[]

  @@map("wa_bot_knowledge")
}

model WABotKnowledgeBot {
  knowledgeId String
  botId        String
  knowledge    WABotKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  bot          WABot          @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@id([knowledgeId, botId])
  @@index([botId])
  @@map("wa_bot_knowledge_bots")
}

model WABotUsage {
  id               String   @id @default(cuid())
  botId            String
  bot              WABot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  waChatId         String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([botId, createdAt])
  @@map("wa_bot_usage")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CUSTOMER
  LOST
}

model Contact {
  id         String     @id @default(cuid())
  accountId  String
  account    WAAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  remoteJid  String
  name       String?
  // Nombre aprendido por un calificador de IA durante la conversación (campo
  // details.nombre_real de WALeadScore) — distinto de `name`, que viene del
  // CSV/hoja de origen (revisado por marketing) y nunca se pisa con esto.
  // Null hasta que algún calificador detecte un nombre real.
  realName   String?
  leadStatus LeadStatus @default(NEW)
  // Reportado por el webhook `user_preferences` de Meta cuando el lead usa el
  // mecanismo nativo de WhatsApp para darse de baja de mensajes de marketing
  // (category "marketing_messages", value "stop"/"resume"). campaign-worker.ts
  // excluye a estos contactos de futuros envíos de campaña — no afecta
  // respuestas manuales/bot en un chat ya iniciado por el lead.
  optedOutMarketing Boolean   @default(false)
  optedOutAt        DateTime?
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  chat  WAChat?
  tags  ContactTag[]
  notes WANote[]

  @@unique([accountId, remoteJid])
  @@index([accountId, leadStatus])
  @@map("contacts")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("accent")
  createdAt DateTime @default(now()) @map("created_at")

  contacts ContactTag[]
  chats    ChatTag[]

  @@map("tags")
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

model ChatTag {
  chatId String
  chat   WAChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([chatId, tagId])
  @@index([tagId])
  @@map("chat_tags")
}

model WANote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([contactId, createdAt])
  @@map("wa_notes")
}

enum NotificationType {
  CHAT_MESSAGE
  CAMPAIGN_COMPLETED
  CAMPAIGN_FAILED
  BOT_ERROR
  BUDGET_EXCEEDED
  // Meta reportó un cambio relevante en la cuenta vía webhook: restricción/baneo
  // (account_update) o baja de calidad/límite de envío (phone_number_quality_update).
  ACCOUNT_STATUS
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, read, createdAt])
  @@map("notifications")
}
