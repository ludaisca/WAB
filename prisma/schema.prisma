generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  name     String?
  email    String   @unique
  password String?
  role     String   @default("user")
  maxOpenChats Int?

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  waAccounts     WAAccount[]
  waCampaigns    WACampaign[]
  waBots         WABot[]
  leadScorerBots WALeadScorerBot[]
  appSettings    AppSettings?
  sharedAccounts WAAccountShare[]
  notes          WANote[]
  chatNotes      WAChatNote[]
  assignedChats  WAChat[]         @relation("ChatAssignments")
  notifications  Notification[]
  sentMessages   WAMessage[]

  @@map("users")
}

model SystemConfig {
  id                 String   @id @default("default")
  allowRegistration  Boolean  @default(true)
  businessName       String?
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model AppSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  openrouterApiKey String?
  googleApiKey     String?
  defaultProvider  String   @default("openrouter")
  defaultModel     String   @default("google/gemini-2.5-flash")
  monthlyBudgetUsd Float?
  budgetAlertMonth String?
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model WAAccount {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  channel         WAChannel        @default(META_CLOUD)
  phoneNumber     String?
  phoneNumberId   String?
  wabaId          String?
  // Meta App ID that owns accessToken — required only for the Resumable Upload
  // API used when creating a template with a media header (distinct from wabaId,
  // which scopes template/message sends). Different WABA accounts can belong to
  // different Meta Apps, so this is per-account rather than a global env var.
  appId           String?
  accessToken     String?
  verifyTokenHash String?
  appSecret       String?
  status            WaAccountStatus  @default(PENDING)
  errorMessage      String?
  lastActivity      DateTime?
  autoAssignEnabled Boolean          @default(false)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  chats           WAChat[]
  templates       WATemplate[]
  campaigns       WACampaign[]
  bots            WABot[]
  sharedWith      WAAccountShare[]
  contacts        Contact[]

  cannedResponses CannedResponse[]

  @@index([phoneNumberId])
  @@unique([phoneNumberId])
  @@unique([userId, name])
  @@map("wa_accounts")
}

model CannedResponse {
  id          String    @id @default(cuid())
  waAccountId String
  waAccount   WAAccount @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  shortcut    String
  content     String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([waAccountId, shortcut])
  @@map("canned_responses")
}

enum WAChannel {
  META_CLOUD
}

model WAAccountShare {
  id          String    @id @default(cuid())
  waAccountId String
  waAccount   WAAccount @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([waAccountId, userId])
  @@map("wa_account_shares")
}

enum WaAccountStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum ChatStatus {
  OPEN
  PENDING
  RESOLVED
}

model WAChat {
  id            String     @id @default(cuid())
  accountId     String
  account       WAAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  remoteJid     String
  name          String?
  isGroup       Boolean    @default(false)
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int        @default(0)
  contactId     String?    @unique
  contact       Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedToId  String?
  assignedTo    User?      @relation("ChatAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)
  status          ChatStatus @default(OPEN)
  resolvedAt      DateTime?
  firstResponseAt DateTime?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  messages         WAMessage[]
  botConversations WABotConversation[]
  chatTags         ChatTag[]
  chatNotes        WAChatNote[]
  leadScores       WALeadScore[]

  @@unique([accountId, remoteJid])
  @@index([assignedToId])
  @@index([accountId, lastMessageAt])
  @@index([accountId, status])
  @@map("wa_chats")
}

model WALeadScorerBot {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                    String
  provider                String
  model                   String
  systemPrompt            String    @db.Text
  isActive                Boolean   @default(true)
  scheduleEnabled         Boolean   @default(false)
  scheduleIntervalMinutes Int?
  scheduleAccountIds      String[]  @default([])
  lastRunAt               DateTime?
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  scores WALeadScore[]
  usage  WALeadScorerUsage[]

  @@unique([userId, name])
  @@map("wa_lead_scorer_bots")
}

model WALeadScorerUsage {
  id               String          @id @default(cuid())
  scorerId         String
  scorer           WALeadScorerBot @relation(fields: [scorerId], references: [id], onDelete: Cascade)
  waChatId         String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([scorerId, createdAt])
  @@map("wa_lead_scorer_usage")
}

model WALeadScore {
  id        String          @id @default(cuid())
  chatId    String
  chat      WAChat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  scorerId  String
  scorer    WALeadScorerBot @relation(fields: [scorerId], references: [id], onDelete: Cascade)
  score     Int
  label     String
  summary   String
  reasons   String
  model     String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([chatId, scorerId])
  @@map("wa_lead_scores")
}

model WAMessage {
  id          String           @id @default(cuid())
  wamid       String?
  chatId      String
  chat        WAChat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  direction   MessageDirection
  messageType String
  body        String?
  caption     String?
  mediaId     String?
  mediaUrl    String?
  mimeType    String?
  filename    String?
  width       Int?
  height      Int?
  duration    Int?
  bytesSize   Int?
  status      String?
  senderId    String?
  sender      User?            @relation(fields: [senderId], references: [id], onDelete: SetNull)
  campaignId  String?
  campaign    WACampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  timestamp   DateTime
  createdAt   DateTime         @default(now()) @map("created_at")

  @@unique([chatId, wamid])
  @@index([wamid])
  @@index([chatId, timestamp])
  @@map("wa_messages")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model WATemplate {
  id          String   @id @default(cuid())
  waAccountId String
  waAccount   WAAccount @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  templateId  String
  name        String
  language    String
  category    String
  status      String
  components  Json
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  campaigns WACampaign[]

  @@unique([waAccountId, templateId])
  @@map("wa_templates")
}

model WACampaign {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  waAccountId     String
  waAccount       WAAccount            @relation(fields: [waAccountId], references: [id], onDelete: Cascade)
  waTemplateId    String
  waTemplate      WATemplate           @relation(fields: [waTemplateId], references: [id], onDelete: Cascade)
  name            String
  status          CampaignStatus       @default(DRAFT)
  // Global values applied to every recipient — unlike body parameters (per-recipient,
  // see WACampaignRecipient.parameters), header text/media and button URL suffixes are
  // the same for the whole campaign in WhatsApp's template model.
  headerParam     String?
  buttonParam     String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  recipientCount  Int                  @default(0)
  sentCount       Int                  @default(0)
  deliveredCount  Int                  @default(0)
  readCount       Int                  @default(0)
  failedCount     Int                  @default(0)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  recipients WACampaignRecipient[]
  messages   WAMessage[]

  @@index([userId])
  @@index([waAccountId])
  @@map("wa_campaigns")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

model WACampaignRecipient {
  id           String          @id @default(cuid())
  campaignId   String
  campaign     WACampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  phoneNumber  String
  contactName  String?
  wamid        String?
  parameters   Json?
  status       RecipientStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?

  @@index([wamid])
  @@index([campaignId, status])
  @@map("wa_campaign_recipients")
}

enum RecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model WABot {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  waAccountId  String?
  waAccount    WAAccount?    @relation(fields: [waAccountId], references: [id], onDelete: SetNull)
  name         String
  provider     String
  model        String
  systemPrompt String        @db.Text
  temperature  Float         @default(0.7)
  maxTokens    Int           @default(1024)
  memoryType   BotMemoryType @default(RECENT)
  memoryLimit  Int           @default(20)
  ragEnabled   Boolean       @default(false)
  humanizeEnabled Boolean    @default(false)
  isActive     Boolean       @default(false)
  status       BotStatus     @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  conversations WABotConversation[]
  knowledgeBots WABotKnowledgeBot[]
  usage         WABotUsage[]

  @@unique([userId, name])
  @@map("wa_bots")
}

enum BotMemoryType {
  NONE
  RECENT
  SUMMARY
}

enum BotStatus {
  ACTIVE
  PAUSED
  ERROR
}

model WABotConversation {
  id              String   @id @default(cuid())
  botId           String
  bot             WABot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  waChatId        String
  waChat          WAChat   @relation(fields: [waChatId], references: [id], onDelete: Cascade)
  summary         String?  @db.Text
  messageCount    Int      @default(0)
  lastInteraction DateTime @default(now())

  @@unique([botId, waChatId])
  @@map("wa_bot_conversations")
}

model WABotKnowledge {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  embedding  Unsupported("vector(768)")
  chunkIndex Int
  sourceName String?
  createdAt  DateTime @default(now()) @map("created_at")

  bots WABotKnowledgeBot[]

  @@map("wa_bot_knowledge")
}

model WABotKnowledgeBot {
  knowledgeId String
  botId        String
  knowledge    WABotKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  bot          WABot          @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@id([knowledgeId, botId])
  @@index([botId])
  @@map("wa_bot_knowledge_bots")
}

model WABotUsage {
  id               String   @id @default(cuid())
  botId            String
  bot              WABot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  waChatId         String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([botId, createdAt])
  @@map("wa_bot_usage")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CUSTOMER
  LOST
}

model Contact {
  id         String     @id @default(cuid())
  accountId  String
  account    WAAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  remoteJid  String
  name       String?
  leadStatus LeadStatus @default(NEW)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  chat  WAChat?
  tags  ContactTag[]
  notes WANote[]

  @@unique([accountId, remoteJid])
  @@index([accountId, leadStatus])
  @@map("contacts")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("accent")
  createdAt DateTime @default(now()) @map("created_at")

  contacts ContactTag[]
  chats    ChatTag[]

  @@map("tags")
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

model ChatTag {
  chatId String
  chat   WAChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([chatId, tagId])
  @@index([tagId])
  @@map("chat_tags")
}

model WANote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([contactId, createdAt])
  @@map("wa_notes")
}

model WAChatNote {
  id        String   @id @default(cuid())
  chatId    String
  chat      WAChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatId, createdAt])
  @@map("wa_chat_notes")
}

enum NotificationType {
  CHAT_MESSAGE
  CAMPAIGN_COMPLETED
  CAMPAIGN_FAILED
  BOT_ERROR
  BUDGET_EXCEEDED
  NOTE_MENTION
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, read, createdAt])
  @@map("notifications")
}
