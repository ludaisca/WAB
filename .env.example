DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wab_db?schema=public"
# openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-here"
# openssl rand -hex 32  (64 hex chars = 32 bytes, AES-256-GCM)
ENCRYPTION_KEY=""
REDIS_URL="redis://redis:6379"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Password del Postgres del docker-compose de producción (default: postgres)
DB_PASSWORD=""

# Integración Google Sheets (leads de Facebook) — opcional
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3001/api/integrations/google-sheets/callback"

# Media de WhatsApp — opcionales, defaults sensatos
# MEDIA_ROOT="/app/media"
# Días de retención de archivos de media descargados; 0 o negativo = no purgar
# MEDIA_RETENTION_DAYS="90"
