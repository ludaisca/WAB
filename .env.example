DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wab_db?schema=public"
# openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-here"
# openssl rand -hex 32  (64 hex chars = 32 bytes, AES-256-GCM)
ENCRYPTION_KEY=""
REDIS_URL="redis://redis:6379"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Password del Postgres del docker-compose de producción (default: postgres)
DB_PASSWORD=""

# Integración Google Sheets (leads de Facebook) — opcional
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3001/api/integrations/google-sheets/callback"

# Media de WhatsApp — opcionales, defaults sensatos
# MEDIA_ROOT="/app/media"
# Días de retención de archivos de media descargados; 0 o negativo = no purgar
# MEDIA_RETENTION_DAYS="90"

# Backups/restauración (sistema de respaldo, ver lib/backup/) — opcionales, defaults sensatos
# BACKUP_ROOT="/app/backups"
# Cuántos backups MANUAL+SCHEDULED se conservan (los más viejos se purgan solos
# tras cada backup exitoso); los PRE_RESTORE nunca se purgan automáticamente
# BACKUP_RETENTION_COUNT="7"
# Timeout del pg_dump/pg_restore en ms
# BACKUP_TIMEOUT_MS="1800000"
# Tamaño máximo aceptado al subir un backup para restaurar, en bytes (default 5GB)
# MAX_RESTORE_UPLOAD_BYTES="5368709120"
